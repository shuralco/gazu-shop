{
    "name": "related_products",
    "label": "Пов'язані товари (варіанти)",
    "description": "Variant picker на картці товару (Розетка-стиль), AJAX-перемикання, RelationManager в адмінці, авто-зв'язування за характеристиками, SEO-лендинги з фільтрів, опції товарів (Колір/Розмір/Об'єм).",
    "version": "1.1.0",
    "author": "Lionex",
    "engine": ">=2.0",
    "php": ">=8.2",
    "requires_modules": [],
    "composer_packages": [],
    "providers": [
        "Modules\\RelatedProducts\\RelatedProductsServiceProvider"
    ],
    "filament_resources": [
        "App\\Filament\\Resources\\FilterLandingResource"
    ],
    "filament_pages": [
        "App\\Filament\\Pages\\VariantPickerSettings"
    ],
    "migrations_path": "database/migrations",
    "views_path": "resources/views",
    "views_namespace": "related_products",
    "routes": "routes/web.php",
    "settings_schema": {
        "picker_enabled": {
            "type": "boolean",
            "default": true,
            "label": "Показувати variant picker на сторінці товару"
        },
        "max_variants_displayed": {
            "type": "integer",
            "default": 50,
            "min": 1,
            "max": 200,
            "label": "Макс. варіантів у picker"
        },
        "auto_relate_per_product": {
            "type": "integer",
            "default": 12,
            "min": 1,
            "max": 50,
            "label": "Макс. авто-зв'язків на товар"
        }
    },
    "enabled_by_default": true
}
