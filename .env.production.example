# ============================================================================
# GAZU — PRODUCTION env шаблон. Скопіюйте в .env.production і заповніть.
#
# ЧЕКЛИСТ ПЕРЕД ДЕПЛОЕМ:
#   [ ] APP_KEY згенеровано (php artisan key:generate)
#   [ ] APP_ENV=production, APP_DEBUG=false
#   [ ] Реальні DB / REDIS паролі (НЕ дефолтні)
#   [ ] SMTP працює (тестове замовлення → лист приходить)
#   [ ] QUEUE_CONNECTION=redis + queue worker запущено (листи/TTN асинхронно)
#   [ ] Платіжний шлюз: ключі + SANDBOX=false, увімкнено gazu_payment_enabled
#   [ ] Checkbox (РРО): реальні логін/ключі, CHECKBOX_ENABLED=true
#   [ ] Демо-дані вичищено: php artisan db:scrub-demo --force
#   [ ] SENTRY_LARAVEL_DSN заданий (моніторинг помилок)
#   [ ] Бекап БД налаштовано
# ============================================================================

APP_NAME="GAZU"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_LOCALE=uk
APP_FALLBACK_LOCALE=uk

LOG_CHANNEL=stack
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null

# --- Database ---------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=your-mysql-host
DB_PORT=3306
DB_DATABASE=gazu
DB_USERNAME=gazu
DB_PASSWORD=__CHANGE_ME__

# --- Cache / Session / Queue (Redis) ----------------------------------------
CACHE_STORE=redis
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_ENCRYPT=true
QUEUE_CONNECTION=redis            # НЕ sync — інакше листи/нотифікації блокують запит

REDIS_CLIENT=phpredis
REDIS_HOST=your-redis-host
REDIS_PASSWORD=__CHANGE_ME__
REDIS_PORT=6379

# --- Mail (SMTP) — без цього не підуть листи про замовлення -----------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=your-email
MAIL_PASSWORD=__CHANGE_ME__
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME="GAZU"

FILESYSTEM_DISK=public

# --- Search (Meilisearch) ---------------------------------------------------
SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=true
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=__CHANGE_ME__

DEFAULT_CURRENCY=UAH

# --- Payment gateways (увімкнути потрібний, SANDBOX=false на проді) ----------
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
LIQPAY_SANDBOX=false

WAYFORPAY_MERCHANT_ACCOUNT=
WAYFORPAY_MERCHANT_SECRET_KEY=
WAYFORPAY_MERCHANT_DOMAIN=your-domain.com
WAYFORPAY_SANDBOX=false

MONOBANK_MERCHANT_ID=
MONOBANK_API_TOKEN=
MONOBANK_WEBHOOK_PUBLIC_KEY=
MONOBANK_SANDBOX=false

# --- Фіскалізація (РРО, Checkbox) — обовʼязково для онлайн-оплати в Україні --
CHECKBOX_ENABLED=false
CHECKBOX_API_URL=https://api.checkbox.ua/api/v1
CHECKBOX_LOGIN=
CHECKBOX_PASSWORD=
CHECKBOX_LICENSE_KEY=
CHECKBOX_CASHIER_NAME=
CHECKBOX_TAX_RATE=20

# --- Image optimization (TinyPNG) ------------------------------------------
TINYPNG_API_KEY=
TINYPNG_ENABLED=false
TINYPNG_MAX_WIDTH=1600
TINYPNG_CONVERT_WEBP=true

# --- Analytics --------------------------------------------------------------
GOOGLE_ANALYTICS_ID=
GOOGLE_TAG_MANAGER_ID=
FACEBOOK_PIXEL_ID=

# --- Error monitoring -------------------------------------------------------
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
